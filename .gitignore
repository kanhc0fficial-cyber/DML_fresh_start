# ============================================================
# 数据文件管理策略
# ============================================================

# 大文件：原始 DCS 数据（16.8 GB，1501 个 .xlsx 文件，单文件最大 103 MB）
# 这些文件太大，必须保持在本地，通过云盘或外部硬盘同步
data/大量长时间数据/**/*.xlsx

# 大型 parquet 文件：超过 100MB 的时序数据（GitHub 限制）
data/X_features_final.parquet
data/timeseries_dataset_final.parquet
data/timeseries_dataset_xin1_final.parquet
data/timeseries_dataset_xin2_final.parquet

# ============================================================
# 允许上传的数据文件（都小于 100MB）
# ============================================================
# 以下文件类型默认会被上传到 GitHub：
# - *.parquet（小文件，如 indicators_final.parquet ~1.7MB）
# - *.csv（配置文件，如白名单 ~0.8MB）
# - *.xls（化验数据 ~0.3MB）
# - *.graphml（因果图结果 ~7KB）✅ 重要！

# ============================================================
# 缓存和临时文件
# ============================================================
data/.cache/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# ============================================================
# 结果目录（可选，根据需要调整）
# ============================================================
# 如果不想上传所有结果文件，可以取消注释：
# **/结果/
# **/logs/
# **/output/
# **/results/

# ============================================================
# Python 环境
# ============================================================
.Python
env/
venv/
.env

# ============================================================
# IDEs
# ============================================================
.vscode/
.idea/
.DS_Store
